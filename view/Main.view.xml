<mvc:View controllerName="ferias1000.controller.Main" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:u="sap.ui.unified" displayBlock="true">
    <App>
        <Page title="Férias 1000">
            <IconTabBar id="idIconTabBar">
                <items>
                    <IconTabFilter icon="sap-icon://wallet" text="Documentos">
                        <VBox class="sapUiSmallMargin">
                            <Panel headerText="Arquivar Novo" expandable="true">
                                <Input id="inputTipo" placeholder="Nome..." />
                                <DatePicker id="inputValidade" />
                                <u:FileUploader id="fileUploader" change="onFileUpload" />
                                <Button text="Salvar" press="onSalvarDoc" type="Emphasized" />
                            </Panel>
                            
                            <List id="listaDocs" items="{path: 'view>/documentos', templateShareable: false}">
                                <CustomListItem press="onVerDocumento">
                                    <HBox alignItems="Center" class="sapUiSmallMargin">
                                        <Text text="{view>tipo}" class="sapUiSmallMarginEnd" />
                                        <Button icon="sap-icon://delete" press="onDeletarDoc" type="Transparent" />
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </Page>
    </App>
</mvc:View>
