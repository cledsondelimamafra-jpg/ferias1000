<mvc:View controllerName="ferias1000.controller.Main" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">
    <Page title="Férias 1000 - Travel Assistant">
        <IconTabBar id="idIconTabBar">
            <items>
                <IconTabFilter text="Explorar" key="tabExplorar">
                    <VBox class="sapUiSmallMargin">
                        <Button id="btnMicrofone" text="Falar Destino" press="onIniciarComandoVoz" type="Emphasized"/>
                        <Text id="txtStatusVoz" text="Aguardando comando..."/>
                        <core:HTML id="map" content="&lt;div id='map' style='height: 300px; width: 100%;'&gt;&lt;/div&gt;"/>
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="Documentos" key="tabDocs">
                    <VBox class="sapUiSmallMargin">
                        <Input id="inputTipoDoc" placeholder="Ex: Passaporte, Visto..."/>
                        <Input id="inputValidadeDoc" type="Date"/>
                        <FileUploader id="fileDoc" change="onFileChange"/>
                        <Button text="Salvar na Carteira" press="onSalvarDoc" type="Accept"/>
                        <List items="{view>/documentos}">
                            <StandardListItem title="{view>tipo}" description="{view>validadeFormatada}" 
                                icon="sap-icon://attachment" press="onVerItem" type="Active"/>
                        </List>
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
    </Page>
</mvc:View>
