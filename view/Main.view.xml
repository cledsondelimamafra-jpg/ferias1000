<mvc:View controllerName="ferias1000.controller.Main" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
    <Page title="Férias 1000 - Travel Assistant">
        <IconTabBar>
            <items>
                <IconTabFilter text="Documentos" icon="sap-icon://documents">
                    <Input value="{view>/novo/tipo}" placeholder="Tipo de documento" />
                    <Button text="Salvar Documento" press="onSalvarDocs" />
                    <List items="{view>/documentos}">
                        <StandardListItem title="{view>tipo}" />
                    </List>
                </IconTabFilter>
            </items>
        </IconTabBar>
    </Page>
</mvc:View>
