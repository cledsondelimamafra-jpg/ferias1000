<mvc:View controllerName="ferias1000.controller.Main" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
    <Page title="Férias 1000 - Meus Documentos">
        <content>
            <VBox class="sapUiSmallMargin">
                <Input id="inputTipo" value="{view>/novoDoc/tipo}" placeholder="Tipo (Ex: RG, Passaporte)" />
                <Button text="Salvar Documento" press="onSalvarDocs" type="Emphasized" />
                <Table items="{view>/documentos}">
                    <columns>
                        <Column><Text text="Documento Salvo" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{view>tipo}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
