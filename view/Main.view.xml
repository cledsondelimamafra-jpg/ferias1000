<mvc:View controllerName="ferias1000.controller.Main" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:u="sap.ui.unified" displayBlock="true">
    <App id="app">
        <Page title="Férias 1000 - Planejador &amp; Carteira">
            <content>
                <IconTabBar id="idIconTabBar" expandable="false" stretchContentHeight="true">
                    <items>
                        <IconTabFilter icon="sap-icon://wallet" text="Documentos">
                            <ScrollContainer vertical="true" height="100%">
                                <VBox class="sapUiSmallMargin">
                                    <Panel headerText="Arquivar Novo Documento" expandable="true" expanded="false">
                                        <VBox class="sapUiSmallMargin">
                                            <Label text="Tipo de Documento" required="true" />
                                            <Input id="inputTipo" placeholder="Ex: Passaporte..." />
                                            <Label text="Data de Validade" required="true" />
                                            <DatePicker id="inputValidade" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd" />
                                            <Label text="Upload da Foto" required="true" />
                                            <u:FileUploader id="fileUploader" buttonText="Escolher Foto" change="onFileUpload" width="100%" />
                                            <Button text="Salvar na Carteira" type="Emphasized" press="onSalvarDoc" icon="sap-icon://save" />
                                        </VBox>
                                    </Panel>
                                    <List id="listaDocs" items="{path: 'view>/documentos', templateShareable: false}" headerText="Meus Documentos Gravados" class="sapUiMediumMarginTop">
                                        <items>
                                            <CustomListItem type="Active">
                                                <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMargin">
                                                    <HBox alignItems="Center">
                                                        <core:Icon src="sap-icon://attachment" size="2rem" class="sapUiSmallMarginEnd" color="{view>estadoColor}" />
                                                        <VBox>
                                                            <Title text="{view>tipo}" />
                                                            <ObjectStatus text="Vencimento: {view>validadeFormatada}" state="{view>estado}" />
                                                        </VBox>
                                                    </HBox>
                                                    <Button icon="sap-icon://delete" type="Transparent" press="onDeletarDoc" />
                                                </HBox>
                                            </CustomListItem>
                                        </items>
                                    </List>
                                </VBox>
                            </ScrollContainer>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </content>
        </Page>
    </App>
</mvc:View>
