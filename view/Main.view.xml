<mvc:View controllerName="ferias1000.controller.Main" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    displayBlock="true">
    <App>
        <Page title="Férias 1000 - Travel Assistant">
            <IconTabBar stretchContentHeight="true">
                <items>
                    <IconTabFilter text="Documentos" icon="sap-icon://documents">
                        <VBox class="sapUiSmallMargin">
                            <Input id="inputDoc" value="{view>/novoDoc/tipo}" placeholder="Digite o documento" />
                            <Button text="Salvar" press="onSalvarDocs" type="Emphasized" />
                            <List items="{view>/documentos}">
                                <StandardListItem title="{view>tipo}" />
                            </List>
                        </VBox>
                    </IconTabFilter>
                    <IconTabFilter text="Mapa" icon="sap-icon://map">
                        <Text text="Mapa ativo - Funcionalidade carregada." />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </Page>
    </App>
</mvc:View>
