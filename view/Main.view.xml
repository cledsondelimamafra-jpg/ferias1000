<mvc:View
    controllerName="ferias1000.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page id="page" title="Férias 1000 - Travel Assistant">
                <content>
                    <IconTabBar id="idIconTabBar" class="sapUiSmallMarginBottom" select="onTabSelect">
                        <items>
                            <IconTabFilter icon="sap-icon://world" text="Explorar" key="explorar" />
                            <IconTabFilter icon="sap-icon://attachment" text="Documentos" key="documentos" />
                            <IconTabFilter icon="sap-icon://home" text="Reservas" key="reservas" />
                            <IconTabFilter icon="sap-icon://flight" text="Passagens" key="passagens" />
                            <IconTabFilter icon="sap-icon://sys-help" text="Manual" key="manual" />
                        </items>
                    </IconTabBar>

                    <VBox id="panelExplorar" visible="true" class="sapUiResponsiveMargin">
                        <Title text="Busca por Comando de Voz" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Button text="Falar Destino" icon="sap-icon://microphone" type="Emphasized" press="onFalarDestino" class="sapUiSmallMarginEnd" />
                            <Text text="Buscando por: '{view>/local/cidade}'" />
                        </HBox>

                        <ToolbarSeparator class="sapUiMediumMarginTopBottom" />

                        <Title text="Clima Atual" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <HBox class="sapUiSmallMarginBottom" width="100%">
                            <VBox width="50%" alignItems="Center">
                                <Label text="Local" design="Bold" />
                                <Text text="{view>/local/cidade}" />
                            </VBox>
                            <VBox width="50%" alignItems="Center">
                                <Label text="Temp" design="Bold" />
                                <Text text="{view>/clima/temp}" />
                            </VBox>
                        </HBox>

                        <ToolbarSeparator class="sapUiMediumMarginTopBottom" />

                        <Title text="Sugestões de Destinos" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        
                        <core:HTML 
                            id="map" 
                            content='&lt;div id="map" style="width: 100%; height: 400px; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"&gt;&lt;/div&gt;'>
                        </core:HTML>

                        <Table items="{view>/lugares}" class="sapUiMediumMarginTop">
                            <columns>
                                <Column><Label text="Ponto Turístico" design="Bold" /></Column>
                                <Column><Label text="Descrição Histórica" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{view>nome}" />
                                        <Text text="{view>desc}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelDocumentos" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tableDocumentos" items="{view>/documentos}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Meus Documentos de Viagem" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarDocumento" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirDocumento" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column><Label text="Tipo de Documento" design="Bold" /></Column>
                                <Column><Label text="Status / Validade" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>tipo}" />
                                        <Input value="{view>status}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelReservas" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tableReservas" items="{view>/reservas}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Minhas Reservas de Hospedagem" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarReserva" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirReserva" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column><Label text="Hospedagem" design="Bold" /></Column>
                                <Column><Label text="Período / Status" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>hotel}" />
                                        <Input value="{view>periodo}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelPassagens" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tablePassagens" items="{view>/passagens}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Passagens Aéreas / Bilhetes" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarPassagem" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirPassagem" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column><Label text="Voo / Companhia" design="Bold" /></Column>
                                <Column><Label text="Assento / Horário" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>voo}" />
                                        <Input value="{view>info}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelManual" visible="false" class="sapUiResponsiveMargin">
                        <Title text="Manual do Assistente de Viagem" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <FormattedText htmlText="&lt;p&gt;&lt;strong&gt;1. Comando de Voz:&lt;/strong&gt; Clique em 'Falar Destino' e diga o nome de uma cidade (Ex: Belém, Niterói).&lt;/p&gt;&lt;p&gt;&lt;strong&gt;2. Clima e Turismo Expandido:&lt;/strong&gt; O sistema trará a temperatura em tempo real e marcará pelo menos 7 pontos históricos proeminentes no mapa automaticamente.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;3. Gestão de Abas:&lt;/strong&gt; Nas abas de Documentos, Reservas e Passagens, use os botões 'Incluir' para adicionar novas linhas digitáveis e selecione os itens desejados usando os checkboxes laterais para efetuar a 'Exclusão'.&lt;/p&gt;" />
                    </VBox>

                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
