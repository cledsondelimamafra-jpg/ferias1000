<mvc:View
    controllerName="ferias1000.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page id="page" title="Férias 1000 - Travel Assistant">
                <content>
                    <IconTabBar id="idIconTabBar" class="sapUiSmallMarginBottom" select="onTabSelect">
                        <items>
                            <IconTabFilter icon="sap-icon://world" text="Explorar" key="explorar" />
                            <IconTabFilter icon="sap-icon://attachment" text="Documentos" key="documentos" />
                            <IconTabFilter icon="sap-icon://home" text="Reservas" key="reservas" />
                            <IconTabFilter icon="sap-icon://flight" text="Passagens" key="passagens" />
                            <IconTabFilter icon="sap-icon://sys-help" text="Manual" key="manual" />
                        </items>
                    </IconTabBar>

                    <VBox id="panelExplorar" visible="true" class="sapUiResponsiveMargin">
                        <Title text="Busca por Comando de Voz" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Button text="Falar Destino" icon="sap-icon://microphone" type="Emphasized" press="onFalarDestino" class="sapUiSmallMarginEnd" />
                            <Text text="Buscando por: '{view>/local/cidade}'" />
                        </HBox>

                        <ToolbarSeparator class="sapUiMediumMarginTopBottom" />

                        <Title text="Clima Atual" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <HBox class="sapUiSmallMarginBottom" width="100%">
                            <VBox width="50%" alignItems="Center">
                                <Label text="Local" design="Bold" />
                                <Text text="{view>/local/cidade}" />
                            </VBox>
                            <VBox width="50%" alignItems="Center">
                                <Label text="Temp" design="Bold" />
                                <Text text="{view>/clima/temp}" />
                            </VBox>
                        </HBox>

                        <ToolbarSeparator class="sapUiMediumMarginTopBottom" />

                        <Title text="Sugestões de Destinos (Mapeamento de Pontos Turísticos Reais)" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        
                        <core:HTML 
                            id="map" 
                            content='&lt;div id="map" style="width: 100%; height: 400px; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"&gt;&lt;/div&gt;'>
                        </core:HTML>

                        <Table items="{view>/lugares}" class="sapUiMediumMarginTop">
                            <columns>
                                <Column><Label text="Ponto Turístico Real" design="Bold" /></Column>
                                <Column><Label text="Categoria" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{view>nome}" />
                                        <Text text="{view>desc}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelDocumentos" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tableDocumentos" items="{view>/documentos}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Meus Documentos de Viagem" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Salvar Dados" icon="sap-icon://save" type="Emphasized" press="onSalvarDados" />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarDocumento" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirDocumento" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column width="35%"><Label text="Tipo de Documento" design="Bold" /></Column>
                                <Column width="25%"><Label text="Validade / Info" design="Bold" /></Column>
                                <Column width="30%"><Label text="Anexar Arquivo" design="Bold" /></Column>
                                <Column width="10%" hAlign="Center"><Label text="Ver" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>tipo}" valueLiveUpdate="true" placeholder="Ex: Passaporte, Visto..." />
                                        <Input value="{view>status}" valueLiveUpdate="true" placeholder="Ex: Válido até 2030" />
                                        <u:FileUploader 
                                            buttonText="Procurar..." 
                                            value="{view>arquivoNome}"
                                            change="onUploadArquivo"
                                            width="100%" />
                                        <Button icon="sap-icon://display" type="Transparent" press="onVisualizarArquivo" enabled="{= ${view>arquivoBase64} !== undefined &amp;&amp; ${view>arquivoBase64} !== '' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelReservas" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tableReservas" items="{view>/reservas}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Minhas Reservas de Hospedagem" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Salvar Dados" icon="sap-icon://save" type="Emphasized" press="onSalvarDados" />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarReserva" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirReserva" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column width="35%"><Label text="Hospedagem / Hotel" design="Bold" /></Column>
                                <Column width="25%"><Label text="Período" design="Bold" /></Column>
                                <Column width="30%"><Label text="Voucher / Comprovante" design="Bold" /></Column>
                                <Column width="10%" hAlign="Center"><Label text="Ver" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>hotel}" valueLiveUpdate="true" placeholder="Nome do Hotel ou Airbnb" />
                                        <Input value="{view>periodo}" valueLiveUpdate="true" placeholder="Ex: 10/10 a 15/10" />
                                        <u:FileUploader 
                                            buttonText="Voucher..." 
                                            value="{view>arquivoNome}"
                                            change="onUploadArquivo"
                                            width="100%" />
                                        <Button icon="sap-icon://display" type="Transparent" press="onVisualizarArquivo" enabled="{= ${view>arquivoBase64} !== undefined &amp;&amp; ${view>arquivoBase64} !== '' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelPassagens" visible="false" class="sapUiResponsiveMargin">
                        <Table id="tablePassagens" items="{view>/passagens}" mode="MultiSelect">
                            <headerToolbar>
                                <OverflowToolbar>
                                    <Title text="Passagens Aéreas / Bilhetes" level="H2" titleStyle="H4" />
                                    <ToolbarSpacer />
                                    <Button text="Salvar Dados" icon="sap-icon://save" type="Emphasized" press="onSalvarDados" />
                                    <Button text="Incluir" icon="sap-icon://add" type="Accept" press="onAdicionarPassagem" />
                                    <Button text="Excluir" icon="sap-icon://delete" type="Reject" press="onExcluirPassagem" />
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column width="35%"><Label text="Voo / Companhia" design="Bold" /></Column>
                                <Column width="25%"><Label text="Assento / Horário" design="Bold" /></Column>
                                <Column width="30%"><Label text="Bilhete Eletrônico" design="Bold" /></Column>
                                <Column width="10%" hAlign="Center"><Label text="Ver" design="Bold" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{view>voo}" valueLiveUpdate="true" placeholder="Ex: LATAM LA4567" />
                                        <Input value="{view>info}" valueLiveUpdate="true" placeholder="Ex: Assento 14A" />
                                        <u:FileUploader 
                                            buttonText="Bilhete..." 
                                            value="{view>arquivoNome}"
                                            change="onUploadArquivo"
                                            width="100%" />
                                        <Button icon="sap-icon://display" type="Transparent" press="onVisualizarArquivo" enabled="{= ${view>arquivoBase64} !== undefined &amp;&amp; ${view>arquivoBase64} !== '' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <VBox id="panelManual" visible="false" class="sapUiResponsiveMargin">
                        <Title text="Manual do Assistente de Viagem" level="H2" titleStyle="H4" class="sapUiSmallMarginBottom" />
                        <FormattedText htmlText="&lt;p&gt;&lt;strong&gt;1. Armazenamento Local:&lt;/strong&gt; Os dados e arquivos anexados são salvos diretamente no banco interno do seu celular corporativo ou pessoal.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;2. Funcionamento Offline:&lt;/strong&gt; Uma vez salvo usando o botão 'Salvar Dados', suas informações permanecem disponíveis mesmo sem sinal de internet.&lt;/p&gt;" />
                    </VBox>

                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
