<Input value="{view>/novoDoc/tipo}" placeholder="RG / Passaporte" />
<Input value="{view>/novoDoc/data}" placeholder="Data" />

<Button text="Salvar Documento" press="onSalvarDocumentos" type="Emphasized" />

<Table items="{view>/documentos}">
    <columns>
        <Column><Text text="Tipo" /></Column>
    </columns>
    <items>
        <ColumnListItem>
            <cells>
                <Text text="{view>tipo}" />
            </cells>
        </ColumnListItem>
    </items>
</Table>
