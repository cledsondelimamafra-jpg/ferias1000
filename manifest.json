{
  "_version": "1.12.0",
  "sap.app": {
    "id": "ferias1000",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "Férias 1000",
    "description": "Travel Assistant",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://flight"
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "ferias1000.view.Main",
      "type": "XML",
      "async": true,
      "id": "mainView"
    },
    "dependencies": {
      "minUI5Version": "1.60.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ferias1000.i18n.i18n"
        }
      },
      "view": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "ferias1000.view",
        "controlId": "mainView",
        "controlAggregation": "pages"
      },
      "routes": [
        {
          "pattern": "",
          "name": "Main",
          "target": "Main"
        }
      ],
      "targets": {
        "Main": {
          "viewName": "Main"
        }
      }
    }
  }
}
