<mvc:View
    controllerName="ferias1000.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <IconTabBar id="idIconTabBar" class="sapUiResponsiveContentPadding">
        <items>
            <IconTabFilter icon="sap-icon://map-2" text="Destinos">
                <VBox spacing="1" class="sapUiSmallMargin">
                    <Title text="Para onde vamos planejar a viagem?" level="H1" titleStyle="H1" class="sapUiSmallMarginBottom" />
                    
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <Button text="Falar Destino" icon="sap-icon://microphone" type="Accept" press="onIniciarComandoVoz" class="sapUiSmallMarginEnd" />
                        <Text text="Clique no microfone para falar seu destino de viagem..." />
                    </HBox>

                    <HBox wrap="Wrap" fitContainer="true" class="sapUiSmallMarginBottom">
                        <VBox width="45%" minWidth="300px" class="sapUiMediumMarginEnd">
                            <Panel headerText="Informações do Destino" width="100%" class="sapUiCard">
                                <form:SimpleForm xmlns:form="sap.ui.layout.form" editable="false" layout="ResponsiveGridLayout">
                                    <Label text="Localidade" />
                                    <Text text="{view>/local/cidade}" />
                                    <Label text="Coordenadas" />
                                    <Text text="{view>/local/coordenadas}" />
                                    <Label text="Temperatura Estimada" />
                                    <Text text="{view>/local/clima}" />
                                </form:SimpleForm>
                            </Panel>
                        </VBox>

                        <VBox width="50%" minWidth="300px">
                            <Panel headerText="Visualização do Mapa" width="100%">
                                <core:HTML content="&lt;div id='mapaDestino' style='width: 100%; height: 400px; border: 1px solid #ccc; border-radius: 4px;'&gt;&lt;/div&gt;" />
                            </Panel>
                        </VBox>
                    </HBox>

                    <Table items="{view>/lugares}" headerText="Sugestões de Atividades" class="sapUiResponsiveMargin">
                        <columns>
                            <Column><Text text="Atração / Atividade" /></Column>
                            <Column><Text text="Categoria" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{view>nome}" />
                                    <Text text="{view>categoria}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://attachment" text="Documentos">
                <VBox class="sapUiSmallMargin">
                    <Title text="Meus Documentos de Viagem" level="H2" class="sapUiSmallMarginBottom" />
                    <Text text="Área reservada para upload de vouchers, RG e passaportes." />
                </VBox>
            </IconTabFilter>

            <IconTabFilter icon="sap-icon://flight" text="Passagens">
                <VBox class="sapUiSmallMargin">
                    <Title text="Informações dos Voos" level="H2" class="sapUiSmallMarginBottom" />
                    <Text text="Dados de embarque, conexões e portões dos terminais." />
                </VBox>
            </IconTabFilter>
        </items>
    </IconTabBar>
</mvc:View>
