<mvc:View
    controllerName="ferias1000.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="page" title="Férias 1000 - Planejador de Destinos">
        <content>
            <VBox class="sapUiSmallMargin">
                <Title text="Para onde vamos planejar a viagem?" level="H1" titleStyle="H1" class="sapUiSmallMarginBottom" />
                
                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <Button text="Falar Destino" icon="sap-icon://microphone" type="Accept" press="onIniciarComandoVoz" class="sapUiSmallMarginEnd" />
                    <Text text="Clique no microfone para falar o seu destino..." />
                </HBox>

                <Panel headerText="Informações do Destino" class="sapUiSmallMarginBottom">
                    <VBox>
                        <HBox class="sapUiTinyMarginBottom">
                            <Text text="Localidade: " renderWhitespace="true" class="sapUiTinyMarginEnd" />
                            <Text text="{view>/local/cidade}" />
                        </HBox>
                        <HBox class="sapUiTinyMarginBottom">
                            <Text text="Coordenadas: " renderWhitespace="true" class="sapUiTinyMarginEnd" />
                            <Text text="{view>/local/coordenadas}" />
                        </HBox>
                        <HBox class="sapUiTinyMarginBottom">
                            <Text text="Temperatura Estimada: " renderWhitespace="true" class="sapUiTinyMarginEnd" />
                            <Text text="{view>/local/clima}" />
                        </HBox>
                    </VBox>
                </Panel>

                <Panel headerText="Visualização do Mapa" class="sapUiSmallMarginBottom">
                    <core:HTML content="&lt;div id='mapaDestino' style='width: 100%; height: 400px; border: 1px solid #ccc; border-radius: 4px;'&gt;&lt;/div&gt;" />
                </Panel>

                <Table items="{view>/lugares}" headerText="Sugestões de Atividades">
                    <columns>
                        <Column><Text text="Atração / Atividade" /></Column>
                        <Column><Text text="Categoria" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{view>nome}" />
                                <Text text="{view>categoria}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
