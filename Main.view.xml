<mvc:View
    controllerName="ferias1000.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page id="page" title="Férias 1000 - Planejador de Destinos">
                <content>
                    <VBox class="sapUiResponsiveMargin">
                        
                        <Title text="Para onde vamos planejar a viagem?" titleStyle="H1" class="sapUiSmallMarginBottom" />
                        
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Button text="Falar Destino" icon="sap-icon://microphone" type="Emphasized" press=".onIniciarComandoVoz" />
                            <Text text="Clique no microfone para falar seu destino de viagem..." class="sapUiSmallMarginBegin" />
                        </HBox>

                        <l:Grid defaultSpan="XL6 L6 M12 S12">
                            
                            <Panel headerText="Informações do Destino">
                                <VBox>
                                    <HBox class="sapUiTinyMarginBottom">
                                        <Label text="Localidade:" design="Bold" />
                                        <Text text="{view>/local/cidade}" class="sapUiSmallMarginBegin"/>
                                    </HBox>
                                    <HBox class="sapUiTinyMarginBottom">
                                        <Label text="Coordenadas:" design="Bold" />
                                        <Text text="{view>/local/coordenadas}" class="sapUiSmallMarginBegin"/>
                                    </HBox>
                                    <HBox class="sapUiTinyMarginBottom">
                                        <Label text="Temperatura Estimada:" design="Bold" />
                                        <Text text="{view>/clima/temp}" class="sapUiSmallMarginBegin"/>
                                    </HBox>
                                </VBox>
                            </Panel>

                            <Panel headerText="Visualização do Mapa">
                                <core:HTML content='&lt;div id="mapaDestino" style="width: 100%; height: 400px; border: 1px solid #ccc;"&gt;&lt;/div&gt;' />
                            </Panel>
                            
                        </l:Grid>

                        <Panel headerText="Sugestões de Atividades" class="sapUiSmallMarginTop">
                            <List items="{view>/lugares}" noDataText="Aguardando a definição do destino...">
                                <StandardListItem title="{view>nome}" description="{view>categoria}" />
                            </List>
                        </Panel>

                    </VBox>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
