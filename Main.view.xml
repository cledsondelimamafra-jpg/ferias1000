<mvc:View
    controllerName="ferias1000.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    height="100%">
    <Shell>
        <App id="appFerias">
            <pages>
                <Page title="Férias 1000 - Planejador de Destinos">
                    <content>
                        <VBox class="sapUiMediumMargin">
                            <Title text="Para onde vamos, Vovô?" level="H1" titleStyle="H1" class="sapUiSmallMarginBottom" />
                            
                            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                <Button id="btnMicrofone" text="Falar Destino" icon="sap-icon://microphone" type="Emphasized" press=".onIniciarComandoVoz" class="sapUiSmallMarginEnd"/>
                                <Text id="txtStatusVoz" text="Clique no microfone para falar seu destino de viagem..." />
                            </HBox>

                            <l:Grid defaultSpan="XL6 L6 M12 S12" vSpacing="1" hSpacing="1">
                                <VBox>
                                    <Panel headerText="Informações do Destino" class="sapUiSmallMarginBottom">
                                        <VBox class="sapUiSmallMargin">
                                            <HBox class="sapUiTinyMarginBottom"><Text text="Localidade: " fontWeight="Bold" class="sapUiTinyMarginEnd"/><Text text="{view>/local/cidade}" /></HBox>
                                            <HBox class="sapUiTinyMarginBottom"><Text text="Coordenadas: " fontWeight="Bold" class="sapUiTinyMarginEnd"/><Text text="{view>/local/coordenadas}" /></HBox>
                                            <HBox class="sapUiTinyMarginBottom"><Text text="Temperatura Estimada: " fontWeight="Bold" class="sapUiTinyMarginEnd"/><Text text="{view>/clima/temp}" /></HBox>
                                        </VBox>
                                    </Panel>

                                    <Panel headerText="Sugestões de Atividades">
                                        <List items="{view>/lugares}">
                                            <StandardListItem title="{view>name}" description="{view>category}" icon="{view>icon}" />
                                        </List>
                                    </Panel>
                                </VBox>

                                <VBox>
                                    <Panel headerText="Visualização do Mapa" height="100%">
                                        <html:div xmlns:html="http://www.w3.org/1999/xhtml" id="mapa_container" class="mapaContainer"></html:div>
                                    </Panel>
                                </VBox>
                            </l:Grid>
                        </VBox>
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
